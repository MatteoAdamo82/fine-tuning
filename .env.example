# ── Dataset Generator ────────────────────────────────────────────────────────
# Scegli uno dei tre provider (GENERATOR in config/base.yaml o --generator CLI)

# Groq (default) — free tier, 14.400 req/day, veloce
# Ottieni la chiave: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio — free tier ma rate limit 429 frequenti
# Ottieni la chiave: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (locale) — nessun rate limit, richiede ollama running localmente
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_GENERATOR_MODEL=qwen3:4b

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Token con write access per push al Hub
HF_TOKEN=your_hf_token_here

# ── Runtime ───────────────────────────────────────────────────────────────────
# Forza CPU anche se GPU disponibile (per test)
# FORCE_CPU=true
