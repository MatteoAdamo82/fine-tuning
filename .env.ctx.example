# Configurazione per ctx-run e ctx-watch (ContextDoc tools)
# Copiare in .env.ctx

CONTEXTDOC_REF=main

# Modello LLM per i conceptual tests (scegliere uno)
# CTX_MODEL=claude-haiku-20240307          # Anthropic (veloce, economico)
# CTX_MODEL=gpt-4o-mini                    # OpenAI
CTX_MODEL=ollama/qwen3:0.6b                # Locale via Ollama (default)

# URL Ollama (se CTX_MODEL usa ollama/)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_BASE=http://host.docker.internal:11434

# API keys (lasciare vuote se si usa Ollama)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
